
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stored user information including balance and role.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "balance": { "type": "number" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "balance", "role"]
    },
    "Deposit": {
      "title": "Deposit",
      "description": "Records of user deposit attempts.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "amount": { "type": "number" },
        "transactionId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "amount", "transactionId", "status"]
    },
    "Withdrawal": {
      "title": "Withdrawal",
      "description": "User withdrawal requests.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "walletAddress": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "completed"] },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "amount", "walletAddress", "status"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "User account data and roles."
    },
    "/deposits/{depositId}": {
      "schema": { "$ref": "#/entities/Deposit" },
      "description": "Tracking user deposits for approval."
    },
    "/withdrawals/{withdrawalId}": {
      "schema": { "$ref": "#/entities/Withdrawal" },
      "description": "Pending and completed withdrawals."
    }
  }
}
